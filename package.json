{
  "name": "finance-dashboard-api",
  "version": "1.0.0",
  "description": "This repo contains REST API for a finance dashboard system built with Node.js, Express, TypeScript, and MongoDB. Features role-based access control, financial record management with filtering and pagination, and aggregated dashboard analytics.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:i": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed:db": "ts-node src/config/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
